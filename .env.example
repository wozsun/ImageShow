# Required for the first administrator initialization.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# Required for the bundled PostgreSQL service and the first app config creation.
POSTGRES_DB=imageshow
POSTGRES_USER=imageshow
POSTGRES_PASSWORD=change-me-db

# Optional Compose host port mappings.
# HOST_PORT=5518
# POSTGRES_HOST_PORT=5432

# Required only when the app container creates its config without the bundled
# PostgreSQL service (for example, a standalone container with an external DB).
# POSTGRES_HOST=database.example.internal
# POSTGRES_PORT=5432

# Optional first-start values. They seed config.json once on first start;
# changing them later does not override an existing configuration file.
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0
# PORT=5518
# SITE_NAME=ImageShow
# APP_DOMAIN=img.example.com

# Reserved subdomain prefixes (see README / docs → 子域名). Each is a single DNS
# label before APP_DOMAIN. Defaults shown.
#   <random>.<APP_DOMAIN> — random-image API
#   <static>.<APP_DOMAIN> — local-storage object host (cookie isolation)
#   <docs>.<APP_DOMAIN>   — reserved for the documentation site
# RANDOM_SUBDOMAIN=random
# STATIC_SUBDOMAIN=static
# DOCS_SUBDOMAIN=docs

# Further behaviour tuning (upload limits, gallery/admin page sizes, preview delay,
# default random method, static base URL override, etc.) is read from the same
# environment but kept out of this example for brevity — see the docs site.
