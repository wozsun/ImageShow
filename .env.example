# Copy to .env and fill in. Only the variables wired into compose.yaml live here;
# every other runtime setting is edited in data/config.json — see config.example.jsonc
# for the full annotated list. The env-var ↔ config.json mapping is uniform: a config
# field <group>.<field> is seeded from the env var <GROUP>_<FIELD> (the top-level `port`
# field uses the bare name PORT).

# Your site's primary domain (config.json site.domain; seeds on first start, default example.com).
SITE_DOMAIN=img.example.com

# Administrator
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# Database (config.json database.*). Feeds both the bundled PostgreSQL service and the app's first config creation.
DATABASE_NAME=imageshow
DATABASE_USER=imageshow
DATABASE_PASSWORD=change-me-db

# Optional host-side port mapping for the app (config.json port; default 5518). If unset, the app is only reachable on the container's internal port.
# HOST_PORT=5518
