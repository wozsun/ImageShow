# Required for the first administrator initialization.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# Required for the bundled PostgreSQL service and the first app config creation.
POSTGRES_DB=imageshow
POSTGRES_USER=imageshow
POSTGRES_PASSWORD=change-me-db

# Optional Compose host port mappings.
# HOST_PORT=5518
# POSTGRES_HOST_PORT=5432

# Required only when the app container creates its config without the bundled
# PostgreSQL service (for example, a standalone container with an external DB).
# POSTGRES_HOST=database.example.internal
# POSTGRES_PORT=5432

# Optional first-start values. They are written to imageshow.config.json once;
# changing them later does not override an existing configuration file.
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0
# PORT=5518
# SITE_NAME=ImageShow
# APP_DOMAIN=img.example.com
# SITE_ICON_URL=/assets/brand/favicon.svg
# ROOT_REDIRECT=home
# Reserved subdomain prefixes (see README → 子域名). Defaults shown.
# RANDOM_SUBDOMAIN=random
# STATIC_SUBDOMAIN=static
# Public base URL for local-storage images. Defaults to
# https://<STATIC_SUBDOMAIN>.<APP_DOMAIN>; set only to override.
# STATIC_BASE_URL=https://static.img.example.com
# HOME_PREVIEW_DELAY_MS=1000
# UPLOAD_MAX_FILE_SIZE_MB=15
# UPLOAD_PRESIGN_EXPIRES_SECONDS=600
# UPLOAD_MAX_LONG_EDGE=8192
# UPLOAD_LIST_PAGE_SIZE=20
# GALLERY_DEFAULT_LIMIT=50
# ADMIN_IMAGE_PAGE_SIZE=50
# RANDOM_DEFAULT_METHOD=redirect
