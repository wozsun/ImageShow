# Copy to .env and fill in. Only the variables wired into compose.yaml live here;
# every other runtime setting is edited in data/config.json — see config.example.jsonc
# for the full annotated list.

# First administrator (seeded into the database on first start).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# Bundled PostgreSQL service + the app's first config creation.
POSTGRES_DB=imageshow
POSTGRES_USER=imageshow
POSTGRES_PASSWORD=change-me-db

# Your site's primary domain (seeds config.json on first start; default example.com).
APP_DOMAIN=img.example.com

# Optional host-side port mappings (the container ports themselves are fixed).
# HOST_PORT=5518
# POSTGRES_HOST_PORT=5432
